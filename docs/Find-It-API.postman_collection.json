            "description": "Public. Customer login with email and password. On success (200), response includes token, userId, email, customerId. Use token in Authorization: Bearer {{token}} for protected customer endpoints.",
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "if (pm.response.code === 200) {",
                    "    var json = pm.response.json();",
                    "    if (json && json.token) {",
                    "        pm.collectionVariables.set('token', json.token);",
                    "        if (typeof pm.environment !== 'undefined' && pm.environment.set) {",
                    "            pm.environment.set('token', json.token);",
                    "        }",
                    "    }",
                    "}"
